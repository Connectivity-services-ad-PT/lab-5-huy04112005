  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Check Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response is JSON and matches HealthStatus schema\", function () {",
                  "    pm.response.to.be.json;",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"status\", \"ok\");",
                  "    pm.expect(body).to.have.property(\"service\");",
                  "    pm.expect(body).to.have.property(\"time\");",
                  "    pm.expect(Date.parse(body.time)).to.not.be.NaN;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST {{baseUrl}}/events/alerts (Gửi sự kiện cảnh báo mới)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"alert.created\",\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2bfff\",\n  \"source\": \"core-business\",\n  \"alertId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2bbbf\",\n  \"severity\": \"HIGH\",\n  \"message\": \"Camera detected unauthorized entry in building B\",\n  \"occurredAt\": \"2026-05-28T00:30:00Z\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2cccf\",\n  \"details\": {\n    \"location\": \"Building B, 2nd Floor\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/alerts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "alerts"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response has eventId and acceptedAt\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"eventId\");",
                  "    pm.expect(json).to.have.property(\"acceptedAt\");",
                  "    pm.environment.set(\"savedEventId\", json.eventId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET {{baseUrl}}/events/{eventId} (Truy vấn chi tiết & trạng thái gửi tin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{savedEventId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{savedEventId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// If mock environment, use the pre-seeded eventId, else use the created one",
                  "if (pm.environment.get(\"env\") === \"mock\") {",
                  "    pm.environment.set(\"savedEventId\", \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response contains delivery history (Send notification / Retry status)\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"event\");",
                  "    pm.expect(json).to.have.property(\"deliveries\");",
                  "    pm.expect(json.deliveries).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Events History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/history?limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "history"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response conforms to AlertEventPage schema\", function () {",
                  "    pm.response.to.be.json;",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"items\");",
                  "    pm.expect(body).to.have.property(\"nextCursor\");",
                  "    pm.expect(body).to.have.property(\"hasMore\");",
                  "    pm.expect(body.items).to.be.an(\"array\");",
                  "    if (pm.environment.get(\"env\") === \"local\") {",
                  "        pm.expect(body.items.length).to.be.greaterThan(0);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
