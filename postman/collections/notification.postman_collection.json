                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "history"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get(\"env\") === \"mock\") {",
                  "    pm.test.skip(\"Skip performance SLA verification in mock environment\");",
                  "} else {",
                  "    pm.test(\"Response time is within acceptable limits (< 200ms)\", function () {",
                  "        pm.expect(pm.response.responseTime).to.be.below(200);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
