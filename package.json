{
  "name": "fit4110-lab04-docker-packaging",
  "version": "0.1.0",
  "private": true,
  "description": "FIT4110 Lab 04 - Docker packaging and Newman verification for Smart Campus services",
  "scripts": {
    "check": "node --version && npm --version",
    "install:cli": "npm install -g @stoplight/spectral-cli@6.11.1 @stoplight/prism-cli@5.14.2",
    "start": "node server.js",
    "lint": "spectral lint contracts/*.yaml",
    "lint:openapi": "spectral lint contracts/*.yaml",
    "lint:contract": "spectral lint contracts/*.yaml",
    "mock:iot": "prism mock contracts/iot-ingestion.openapi.yaml --host 0.0.0.0 --port 4010",
    "test:mock": "newman run postman/collections/FIT4110_lab04_iot_docker.postman_collection.json -e postman/environments/FIT4110_lab04_mock.postman_environment.json -r cli,junit,htmlextra",
    "test:local": "newman run postman/collections/FIT4110_lab04_iot_docker.postman_collection.json -e postman/environments/FIT4110_lab04_local.postman_environment.json -r cli,junit,htmlextra",
    "test": "node scripts/test-runner.js all"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "@stoplight/spectral-cli": "^6.13.1",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}
